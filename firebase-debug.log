[debug] [2026-07-02T05:26:09.062Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/dev-soc-registrations/rulesets {"name":"projects/dev-soc-registrations/rulesets/806e5b90-ea6b-40f6-81da-f75906421c5d","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper: check if the requesting user is an admin\n    function isAdmin() {\n      return request.auth != null\n        && exists(/databases/$(database)/documents/users/$(request.auth.uid))\n        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == \"admin\";\n    }\n\n    // Users: any authenticated user can read any user doc\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      // Users can only create their own document if they set their role to user\n      allow create: if request.auth != null && request.auth.uid == userId \n                    && request.resource.data.role == \"user\";\n      // Users can only update their own document if they don't change their role\n      allow update: if request.auth != null && request.auth.uid == userId \n                    && request.resource.data.role == resource.data.role;\n      // Admins can manage all users\n      allow delete, update, create: if isAdmin();\n    }\n\n    // Careers: anyone can read, only admins can write\n    match /careers/{careerId} {\n      allow read: if true;\n      allow create, update, delete: if isAdmin();\n    }\n\n    // Admin requests: Users can only create requests for their own email\n    match /admin_requests/{requestId} {\n      allow create: if request.auth != null && request.resource.data.email == request.auth.token.email;\n      allow read, update, delete: if isAdmin();\n    }\n\n    // Applications: Users can read/write their own applications, admins can read/write all\n    match /applications/{appId} {\n      // User must be authenticated\n      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;\n      // Allow user to read/update their own application, or admins to read/update all\n      allow read, update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());\n      // Only admins can delete\n      allow delete: if isAdmin();\n    }\n  }\n}\n\n","name":"firestore.rules"}]},"createTime":"2026-07-02T05:26:08.937711Z","metadata":{"services":["cloud.firestore"]}}
